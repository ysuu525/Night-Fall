# Absolute path to the user's existing Ombre Brain installation.
# Local example:
# OMBRE_HOME=/Users/you/Downloads/Ombre-Brain

# Optional Night Fall storage override.
# Local default is ./data; Docker override sets /data/night_fall.
# NIGHT_FALL_DATA_DIR=/absolute/path/to/night_fall_data

# Optional surfacing behavior.
# NIGHT_FALL_SURFACE_THRESHOLD=0.82
# NIGHT_FALL_SPONTANEOUS_CHANCE=0.02

# Optional direct DeepSeek/OpenAI-compatible provider for Night Fall generation.
# If omitted, Night Fall reuses Ombre's configured dehydration client when available.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
